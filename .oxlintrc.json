{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist/**", "node_modules/**", ".repos/**"],
  "jsPlugins": ["./oxlint-plugin-effect-auth.ts"],
  "rules": {
    "effect-auth/no-explicit-any": "error",
    "effect-auth/no-type-casting": "error",
    "effect-auth/no-non-null-assertion": "error",
    "effect-auth/no-disable-validation": "error",
    "effect-auth/no-sql-type-parameter": "error",
    "effect-auth/prefer-option-from-nullable": "warn",
    "effect-auth/no-effect-ignore": "error",
    "effect-auth/no-effect-catchallcause": "error",
    "effect-auth/no-silent-error-swallow": "error",
    "effect-auth/no-service-option": "error",
    "effect-auth/no-nested-layer-provide": "warn",
    "effect-auth/no-void-expression": "error",
    "effect-auth/no-direct-fetch": "error",
    "effect-auth/no-localstorage": "error",
    "effect-auth/no-manual-layer-build-in-tests": "warn",
    "effect-auth/prefer-effect-vitest": "warn",
    "effect-auth/prefer-effect-vitest-assert": "warn"
  }
}
