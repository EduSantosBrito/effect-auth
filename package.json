{
  "name": "effect-auth-monorepo",
  "private": true,
  "description": "Monorepo for effect-auth.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --cwd packages/effect-auth build",
    "check": "bun run --cwd packages/effect-auth check && bun run --cwd examples/minimal check",
    "format": "bun --bun oxfmt --ignore-path .oxfmtignore --write .",
    "format:check": "bun --bun oxfmt --ignore-path .oxfmtignore --check .",
    "lint": "bun run --cwd packages/effect-auth lint",
    "example:minimal": "bun run build && bun run --cwd examples/minimal start",
    "test": "bun run --cwd packages/effect-auth test",
    "prepare": "bun --bun effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/tsgo": "0.5.2",
    "@effect/vitest": "^4.0.0-beta.64",
    "@types/bun": "latest",
    "@typescript/native-preview": "latest",
    "effect-rules": "0.1.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "vitest": "^4.1.5"
  }
}
