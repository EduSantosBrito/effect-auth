{
  "name": "effect-auth",
  "version": "0.5.0",
  "description": "Server-side authentication for Effect applications.",
  "keywords": [
    "auth",
    "authentication",
    "effect",
    "password",
    "sessions",
    "typescript"
  ],
  "homepage": "https://github.com/EduSantosBrito/effect-auth#readme",
  "bugs": {
    "url": "https://github.com/EduSantosBrito/effect-auth/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EduSantosBrito/effect-auth.git",
    "directory": "packages/effect-auth"
  },
  "bin": {
    "effect-auth": "./dist/cli.js"
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    },
    "./password": {
      "types": "./dist/password/index.d.ts",
      "import": "./dist/password/index.js"
    },
    "./token": {
      "types": "./dist/token/index.d.ts",
      "import": "./dist/token/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./storage/dev-memory": {
      "types": "./dist/storage/dev-memory.d.ts",
      "import": "./dist/storage/dev-memory.js"
    },
    "./storage/drizzle-pg": {
      "types": "./dist/storage/drizzle-pg/index.d.ts",
      "import": "./dist/storage/drizzle-pg/index.js"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js"
    },
    "./email/mock": {
      "types": "./dist/email/mock.d.ts",
      "import": "./dist/email/mock.js"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit/index.d.ts",
      "import": "./dist/rate-limit/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "import": "./dist/oauth/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rm -rf dist && bun --bun tsgo -p tsconfig.build.json",
    "check": "bun --bun tsgo -p tsconfig.json --noEmit && bun run lint",
    "format": "bun --bun oxfmt --write .",
    "format:check": "bun --bun oxfmt --check .",
    "lint": "bun --bun oxlint -c ../../oxlint.config.ts .",
    "package:smoke": "bun run build && npm pack --dry-run",
    "prepack": "bun run build",
    "test": "bun --bun vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "effect": "^4.0.0-beta.64"
  },
  "devDependencies": {
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "effect-rules": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/sql": "*",
    "@effect/sql-pg": "^4.0.0-beta.64",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependenciesMeta": {
    "@effect/sql": {
      "optional": true
    },
    "@effect/sql-pg": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  }
}
