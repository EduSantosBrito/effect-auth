{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "jsPlugins": ["effect-rules"],
  "rules": {
    "effect/no-explicit-any": "error",
    "effect/no-type-casting": "error",
    "effect/no-non-null-assertion": "error",
    "effect/no-ts-nocheck": "error",
    "effect/no-disable-validation": "error",
    "effect/no-sql-type-parameter": "error",
    "effect/prefer-option-from-nullable": "error",
    "effect/no-effect-ignore": "error",
    "effect/no-effect-catchallcause": "error",
    "effect/no-effect-escape-hatch": "error",
    "effect/no-unsupported-effect-api": "error",
    "effect/no-silent-error-swallow": "error",
    "effect/no-service-option": "error",
    "effect/no-nested-layer-provide": "error",
    "effect/no-void-expression": "error",
    "effect/no-direct-fetch": "error",
    "effect/no-json-parse": "error",
    "effect/no-unknown-shape-probing": "error",
    "effect/no-localstorage": "error",
    "effect/no-manual-layer-build-in-tests": "error",
    "effect/no-vitest-import": "error",
    "effect/prefer-effect-vitest": "error",
    "effect/prefer-effect-vitest-assert": "error",
    "effect/prefer-yieldable-error": "error",
    "effect/no-effect-fail-new-error": "error",
    "effect/no-built-in-error-constructor": "error",
    "effect/no-raw-throw": "error",
    "effect/no-instanceof-error": "error",
    "effect/no-unknown-error-message": "error",
    "effect/no-promise-catch": "error",
    "effect/no-promise-reject": "error",
    "effect/prefer-tagged-constructor": "error",
    "effect/no-manual-tag-check": "error",
    "effect/prefer-schema-tagged-error-class": "error",
    "effect/prefer-effect-fn": "error",
    "effect/prefer-match-validation": "error",
    "effect/prefer-yieldable-error-in-match": "error",
    "effect/no-as-effect-method-reference": "error",
    "effect/prefer-context-service": "error",
    "effect/no-inline-schema-compile": "error",
    "effect/no-try-catch": "error"
  }
}
