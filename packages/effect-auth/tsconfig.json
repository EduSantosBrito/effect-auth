{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "effect-auth": ["./src/index.ts"],
      "effect-auth/domain": ["./src/domain/index.ts"],
      "effect-auth/email": ["./src/email/index.ts"],
      "effect-auth/http": ["./src/http/index.ts"],
      "effect-auth/password": ["./src/password/index.ts"],
      "effect-auth/rate-limit": ["./src/rate-limit/index.ts"],
      "effect-auth/storage/drizzle-pg": ["./src/storage/drizzle-pg.ts"],
      "effect-auth/storage": ["./src/storage/index.ts"],
      "effect-auth/token": ["./src/token/index.ts"],
      "effect-auth/workflows": ["./src/workflows/index.ts"]
    },
    "lib": ["ES2022"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "asyncFunction": "error",
          "cryptoRandomUUID": "error",
          "cryptoRandomUUIDInEffect": "error",
          "extendsNativeError": "error",
          "globalConsole": "error",
          "globalConsoleInEffect": "error",
          "globalDate": "error",
          "globalDateInEffect": "error",
          "globalFetch": "error",
          "globalFetchInEffect": "error",
          "globalRandom": "error",
          "globalRandomInEffect": "error",
          "globalTimers": "error",
          "globalTimersInEffect": "error",
          "instanceOfSchema": "error",
          "newPromise": "error",
          "nodeBuiltinImport": "error",
          "preferSchemaOverJson": "error",
          "processEnv": "error",
          "processEnvInEffect": "error"
        }
      }
    ]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "$schema": "https://raw.githubusercontent.com/Effect-TS/tsgo/refs/heads/main/schema.json"
}
